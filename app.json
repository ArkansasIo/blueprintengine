{
  "name": "steercode-project",
  "slug": "steercode-project",
  "version": "1.0.0",
  "orientation": "portrait",
  "scheme": "myapp",
  "userInterfaceStyle": "automatic",
  "newArchEnabled": true,
  "ios": {
    "supportsTablet": true
  },
  "android": {
    "edgeToEdgeEnabled": true
  },
  "web": {
    "bundler": "metro",
    "output": "single"
  },
  "plugins": [
    "expo-router"
  ],
  "experiments": {
    "typedRoutes": true
  }
}
